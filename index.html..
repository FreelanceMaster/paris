    '<div class="autres">'+esc(label1N2)+'</div>'+
    '<div class="bars">'+pb('1 — '+abbr(m.t1),rl.pW,'1')+pb('Nul',rl.pD,'X')+pb('2 — '+abbr(m.t2),rl.pL,'2')+'</div>'+
    '<div class="mktbox" id="mkt_'+i+'"></div>'+
    (isLive?'':
      '<div class="autres">Forme dans le tournoi (jauge de victoires)</div>'+
      '<div class="formbox">'+formRow(m.t1)+formRow(m.t2)+'</div>'+
      ((RATING[m.t1]||RATING[m.t2])?'<div class="fifaline">Niveau des équipes : '+abbr(m.t1)+' '+(RATING[m.t1]||'—')+' pts · '+abbr(m.t2)+' '+(RATING[m.t2]||'—')+' pts</div>':'')+
      ((FORM[m.t1]||FORM[m.t2])?'<div class="fifaline">Forme récente : '+abbr(m.t1)+' '+formStr(m.t1)+' · '+abbr(m.t2)+' '+formStr(m.t2)+'</div>':'')
    )+
