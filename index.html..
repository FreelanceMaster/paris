      ((adj.a!==1||adj.b!==1)?'<div class="compnote">✓ Pronostic ajusté selon les compos.</div>':'')+'</div>'
    )+
    '<div class="autres">'+(isLive?'⚡ Double chance — probabilités live':'Double chance — appuie pour tester la cote')+'</div>'+
    '<div class="bars2">'+pb('1 ou Nul',rl.pW+rl.pD,'DC1X')+pb('Nul ou 2',rl.pD+rl.pL,'DCX2')+pb(abbr(m.t1)+' ou '+abbr(m.t2),rl.pW+rl.pL,'DC12')+'</div>'+
    '<div class="autres">'+(isLive?'⚡ Nombre de buts — recalculé avec '+homeG+' buts déjà marqués':'Nombre de buts (plus / moins)')+'</div>'+
    '<div class="bars2">'+
      pb('+0,5 but',rl.o05,'O05')+pb('−0,5 but',1-rl.o05,'U05')+
      pb('+1,5 buts',rl.o15,'O15')+pb('−1,5 buts',1-rl.o15,'U15')+
      pb('+2,5 buts',rl.o25,'O25')+pb('−2,5 buts',1-rl.o25,'U25')+
      pb('+3,5 buts',rl.o35,'O35')+pb('−3,5 buts',1-rl.o35,'U35')+'</div>'+
