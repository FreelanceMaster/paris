function predHtml(m,i){
  var adj=ADJ[i]||{a:1,b:1};
  var isLive=(statusOf(m)==='live');

  // ── Calcul des lambda de base (avant-match) ──
  var r=predictMatch(m,adj.a,adj.b);

  // ── Si match en cours : recalcul live sur toutes les probabilités ──
  var rl=r; // résultat live = base par défaut
  var homeG=0, awayG=0, elapsed=0;
  if(isLive && m.scoreHome!=null){
    homeG=m.scoreHome; awayG=m.scoreAway||0; elapsed=m.elapsed||0;
    var minLeft=Math.max(1, 95-elapsed);  // minutes restantes estimées
    // Buts encore attendus (proportionnel au temps restant)
    var lARem=Math.max(0.05, r.lA * minLeft/90);
    var lBRem=Math.max(0.05, r.lB * minLeft/90);
    // Recalcul Poisson sur le reste du match
    var M=12, pW=0, pD=0, pL=0;
    var o05=0,o15=0,o25=0,o35=0,btts=false,pA1=0,pB1=0,pNo=0;
    var bestP=0, bestScore='';
    for(var x=0;x<=M;x++)for(var y=0;y<=M;y++){
      var p=pois(x,lARem)*pois(y,lBRem);
      var fh=homeG+x, fa=awayG+y, tot=fh+fa, totNew=x+y;
      if(fh>fa)pW+=p; else if(fh===fa)pD+=p; else pL+=p;
      if(tot>0.5)o05+=p; if(tot>1.5)o15+=p; if(tot>2.5)o25+=p; if(tot>3.5)o35+=p;
      if(p>bestP){bestP=p;bestScore=fh+'-'+fa;}
    }
    // BTTS : déjà marqué ou va marquer
    btts=(homeG>0&&awayG>0)||
         (homeG>0&&(1-Math.exp(-lBRem))>0.01)||
         (awayG>0&&(1-Math.exp(-lARem))>0.01)||
         ((1-Math.exp(-lARem))*(1-Math.exp(-lBRem))>0.15);
    var pBTTS=(homeG>0&&awayG>0)?1:
      (homeG>0)?(1-Math.exp(-lBRem)):
      (awayG>0)?(1-Math.exp(-lARem)):
      (1-Math.exp(-lARem))*(1-Math.exp(-lBRem));
    // Recalcul mi-temps : si déjà > 45min, mi-temps connue
    var htW=elapsed<45?r.htW:homeG>awayG?1:0;
    var htD=elapsed<45?r.htD:homeG===awayG?1:0;
    var htL=elapsed<45?r.htL:homeG<awayG?1:0;
    rl={pW:pW,pD:pD,pL:pL,
        o05:o05,o15:o15,o25:o25,o35:o35,
        btts:pBTTS, pA1st:r.pA1st, pB1st:r.pB1st, pNoGoal:pNo,
        htW:htW,htD:htD,htL:htL,
        lA:r.lA,lB:r.lB, score:bestScore||r.score,
        played:r.played,restA:r.restA,restB:r.restB,hostA:r.hostA,hostB:r.hostB};
  }

  function odd(p){return p>0?(1/p).toFixed(2):'—';}
  function pb(lbl,p,key){
    return '<div class="pb" onclick="event.stopPropagation();sendToValue('+i+",'"+key+"',"+p.toFixed(4)+')">'+
      '<div class="o">'+lbl+'</div><div class="p">'+(p*100).toFixed(0)+'%</div>'+
      '<div class="c">cote juste '+odd(p)+'</div><div class="send">→ tester une cote</div></div>';
  }

  var weak=rl.played<1?'<div class="note">ℹ Peu de matchs joués : le pronostic s\'appuie surtout sur le niveau des équipes.</div>':'';
  var facs=[];
  if(rl.restA!=null||rl.restB!=null)facs.push('Repos : '+abbr(m.t1)+' '+(rl.restA!=null?rl.restA+'j':'—')+' · '+abbr(m.t2)+' '+(rl.restB!=null?rl.restB+'j':'—'));
  if(rl.hostA)facs.push('Avantage hôte : '+abbr(m.t1));
  if(rl.hostB)facs.push('Avantage hôte : '+abbr(m.t2));
  var facHtml=facs.length?'<div class="facnote">⚙ Facteurs — '+facs.join(' · ')+'</div>':'';

  var nmin=Math.min((STR[m.t1]||{n:0}).n,(STR[m.t2]||{n:0}).n);
  var conf=nmin>=3?['Bonne','cbon']:nmin>=2?['Moyenne','cmoy']:['Faible','cfaible'];
  var top=[[rl.pW,'Victoire '+abbr(m.t1)],[rl.pD,'Match nul'],[rl.pL,'Victoire '+abbr(m.t2)]].sort(function(a,b){return b[0]-a[0];})[0];
  var cp=Math.round(top[0]*100);
  var cbar='<div class="confwrap"><div class="conflab"><span>Plus probable : <b>'+esc(top[1])+'</b></span><span>'+cp+'%</span></div><div class="confbar"><i style="width:'+cp+'%"></i></div></div>';

  // Badge LIVE ou Fiabilité
  var badgeLive=isLive?
    '<span class="cbadge" style="background:rgba(255,77,109,.2);color:var(--live);animation:blink 1.4s infinite">● EN DIRECT '+homeG+'-'+awayG+(elapsed?' · '+elapsed+"'":'')+'</span>'+
    '<span class="cbadge" style="background:rgba(0,230,118,.1);color:var(--gold-soft);margin-left:6px">Probabilités recalculées live</span>':
    '<span class="cbadge '+conf[1]+'">Fiabilité '+conf[0]+'</span>';

  var headInfo='<div class="predhead">'+badgeLive+'</div>'+cbar+
    (isLive?'':''+comparisonHtml(m,r))+
    '<div class="analysis">'+esc(buildAnalysis(m,rl))+'</div>';

  // Label contextuel selon état
  var label1N2=isLive?
    ('⚡ Résultat final — probabilités recalculées à '+elapsed+"' ("+homeG+'-'+awayG+')'):
