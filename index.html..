function fatigueFactor(m,team){
  var prev=null;
  for(var k=0;k<MATCHES.length;k++){var x=MATCHES[k];
    if(x.ko>=m.ko)continue;
    if(x.t1===team||x.t2===team){if(prev===null||x.ko>prev)prev=x.ko;}}
  if(prev===null)return {f:1,days:null};
  var days=Math.round((m.ko-prev)/86400000);
  var f=days>=4?1:days===3?0.97:days===2?0.94:0.90;
  return {f:f,days:days};
}
function predictMatch(m,qLA,qLB){
  qLA=qLA||1; qLB=qLB||1;
  var a=strength(m.t1),b=strength(m.t2);
  var fa=fatigueFactor(m,m.t1), fb=fatigueFactor(m,m.t2);   // fatigue / repos
  var qA=qLA*fa.f, qB=qLB*fb.f;                             // effectif x fraîcheur
  var lA=(a.att*qA)*(b.def/qB)*AVG, lB=(b.att*qB)*(a.def/qA)*AVG;
  var hostA=isHostHome(m,m.t1), hostB=isHostHome(m,m.t2);   // avantage du pays hôte
  if(hostA){lA*=1.12; lB*=0.93;}
  if(hostB){lB*=1.12; lA*=0.93;}
  lA=Math.max(0.2,lA); lB=Math.max(0.2,lB);
  var r=model(lA,lB);
  var ht=model(lA*0.45,lB*0.45);   // mi-temps : ~45% des buts tombent en 1re periode
  r.htW=ht.pW; r.htD=ht.pD; r.htL=ht.pL;
  r.played=Math.min(a.n,b.n);
  r.restA=fa.days; r.restB=fb.days; r.hostA=hostA; r.hostB=hostB;
  return r;
}

