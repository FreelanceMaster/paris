  var res=document.getElementById('ana-res');
  var verd=document.getElementById('ana-verdict');
  var imp=document.getElementById('ana-imp');
  var ev=document.getElementById('ana-ev');
  res.style.display='block';
  if(cote&&cote>1){
    var ev_val=p*cote-1;
    var good=ev_val>0;
    res.className='vres '+(good?'good':'bad');
    verd.className='verdict '+(good?'good':'bad');
    verd.textContent=good?'✓ Statistiquement favorable':'✕ Pas favorable selon l\'analyse';
    imp.textContent=(1/cote*100).toFixed(1)+'%';
    ev.textContent=(ev_val>=0?'+':'')+(ev_val*100).toFixed(1)+'%';
  } else {
    res.className='vres good';
    verd.className='verdict good';
    verd.textContent='Probabilité estimée : '+(p*100).toFixed(0)+'%  ·  Cote juste : '+(p>0?(1/p).toFixed(2):'—');
