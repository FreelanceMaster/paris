/* ---------- enrichissement marché : cotes des bookmakers via l'agent ---------- */
function impliedFromOdds(o){var x=parseFloat(o);return (x&&x>1)?1/x:0;}
function marketConsensus(oddsArr){
  try{
    var blocks=oddsArr||[], books=(blocks[0]&&blocks[0].bookmakers)||[];
    var sh=0,sd=0,sa=0,n=0;
    books.forEach(function(b){
      var mw=(b.bets||[]).find(function(x){return x.name==='Match Winner';});
      if(!mw)return;
      var vh,vd,va;
      (mw.values||[]).forEach(function(v){
        if(v.value==='Home')vh=impliedFromOdds(v.odd);
        else if(v.value==='Draw')vd=impliedFromOdds(v.odd);
        else if(v.value==='Away')va=impliedFromOdds(v.odd);
      });
      if(vh&&vd&&va){var s=vh+vd+va; sh+=vh/s; sd+=vd/s; sa+=va/s; n++;}
    });
    if(n===0)return null;
    return {h:sh/n,d:sd/n,a:sa/n,books:n};
  }catch(e){return null;}
}
var MKT_BLEND=0.45;
async function enrichMatch(i){
  var host=document.getElementById('mkt_'+i),m=MATCHES[i];
  if(!host||!m||!m.fid)return;
  host.innerHTML='<div class="mktload">Analyse du marché en cours…</div>';
  try{
    var j=await fetch(AGENT+'/prematch.json?fixture='+m.fid,{cache:'no-store'}).then(function(r){return r.json();});
    var mk=marketConsensus(j.odds);
    if(!mk){host.innerHTML='';return;}
    var adj=ADJ[i]||{a:1,b:1}, r=predictMatch(m,adj.a,adj.b);
    // Mélange : 55% modèle / 45% marché
    var bh=(1-MKT_BLEND)*r.pW+MKT_BLEND*mk.h;
    var bd=(1-MKT_BLEND)*r.pD+MKT_BLEND*mk.d;
    var ba=(1-MKT_BLEND)*r.pL+MKT_BLEND*mk.a;
    var bs=bh+bd+ba||1; bh/=bs;bd/=bs;ba/=bs;
    function od(p){return p>0?(1/p).toFixed(2):'—';}
    function pbm(lbl,p,key){
      return '<div class="pb" onclick="event.stopPropagation();sendToValue('+i+",'"+key+"',"+p.toFixed(4)+')">'+
        '<div class="o">'+lbl+'</div><div class="p">'+(p*100).toFixed(0)+'%</div>'+
        '<div class="c">cote juste '+od(p)+'</div><div class="send">→ tester</div></div>';
    }
    // Remplacer directement les barres 1/N/2 du haut par la version affinée
    var newBars='<div class="bars">'+pbm('1 — '+abbr(m.t1),bh,'1')+pbm('Nul',bd,'X')+pbm('2 — '+abbr(m.t2),ba,'2')+'</div>';
    // Chercher et remplacer les barres originales dans le DOM
    var body=document.getElementById('mb'+i);
    if(body){
      var existing=body.querySelector('.bars');
      if(existing){
        var tmp=document.createElement('div');
        tmp.innerHTML=newBars;
        existing.replaceWith(tmp.firstChild);
      }
    }
    host.innerHTML=''; // pas de bloc supplémentaire — tout est dans les barres
  }catch(e){host.innerHTML='';}
}
