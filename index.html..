  var stats=document.getElementById('montante-stats');
  if(!host)return;
  // utiliser les paris existants comme source
  var bets=store.bets.slice().reverse().slice(0,15);
  if(bets.length===0){
    host.innerHTML='<div class="empty">Aucune prédiction enregistrée. Ajoute des pronostics dans l\'onglet Paris.</div>';
    if(graph)graph.innerHTML='';
    return;
  }
  var solde=store.start, points=[solde], wins=0, total=0;
  var html=bets.map(function(b){
    var res=b.res,pl=0,cls='badge-p',lbl='En attente';
    if(res==='won'){pl=b.stake*(b.odds-1);wins++;total++;cls='badge-w';lbl='✅ Réussi';}
    else if(res==='lost'){pl=-b.stake;total++;cls='badge-l';lbl='❌ Raté';}
    else if(res==='void'){lbl='Annulé';}
    if(res==='won'||res==='lost'){solde+=pl;points.push(parseFloat(solde.toFixed(2)));}
    var plStr=pl>0?'+'+(pl).toFixed(2)+'':pl<0?(pl).toFixed(2)+'':'—';
    return '<div class="montante-card">'+
      '<div class="top"><div>'+
        '<div class="match">'+esc(b.m)+'</div>'+
        '<div class="pick">'+esc(b.sel||'—')+'</div>'+
      '</div><div style="text-align:right">'+
        '<span class="badge-res '+cls+'">'+lbl+'</span>'+
        '<div class="pl '+(pl>0?'pos':pl<0?'neg':'pend')+'" style="margin-top:6px;font-family:var(--mono);font-weight:700;font-size:14px">'+plStr+'</div>'+
      '</div></div>'+
      '<div class="meta">Cote '+b.odds.toFixed(2)+' · Mise '+b.stake.toFixed(2)+'</div>'+
    '</div>';
  }).join('');
  host.innerHTML=html;
  // stats résumé
  var roi=store.start>0?((solde-store.start)/store.start*100):0;
  if(stats)stats.innerHTML='<div class="reccard" style="margin-bottom:0"><div class="reclab">📊 Bilan Montante IA</div>'+
    '<div class="recmain"><b>'+(total>0?Math.round(wins/total*100):0)+'%</b> de réussite</div>'+
    '<div class="recbars">'+
      '<div class="recbar"><span>Solde actuel</span><b>'+solde.toFixed(2)+'</b></div>'+
      '<div class="recbar"><span>ROI</span><b>'+(roi>=0?'+':'')+roi.toFixed(1)+'%</b></div>'+
      '<div class="recbar"><span>Prédictions</span><b>'+total+' jugées</b></div>'+
    '</div></div>';
  // graphique SVG
  if(graph&&points.length>1){
    var W=graph.offsetWidth||340,H=76;
    var mn=Math.min.apply(null,points),mx=Math.max.apply(null,points);
    var rng=mx-mn||1;
    function px(i){return Math.round(i/(points.length-1)*(W-4)+2);}
    function py(v){return Math.round((1-(v-mn)/rng)*(H-8)+4);}
    var d=points.map(function(v,i){return (i===0?'M':'L')+px(i)+' '+py(v);}).join(' ');
    var col=solde>=store.start?'var(--gold)':'var(--red)';
    graph.innerHTML='<svg width="'+W+'" height="'+H+'" viewBox="0 0 '+W+' '+H+'">'
      +'<polyline points="'+points.map(function(v,i){return px(i)+','+py(v);}).join(' ')+'" fill="none" stroke="'+col+'" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>'
      +'<circle cx="'+px(points.length-1)+'" cy="'+py(points[points.length-1])+'" r="4" fill="'+col+'"/>'
      +'</svg>';
  }
}

/* ---------- historique des prédictions ---------- */
function renderHistorique(){
  var host=document.getElementById('hist-list');
  var sc=document.getElementById('hist-score');
  if(!host)return;
  var bets=store.bets.slice();
  if(bets.length===0){
    host.innerHTML='<div class="empty">Aucune prédiction enregistrée.</div>';
    return;
  }
  var w=0,l=0;
  bets.forEach(function(b){if(b.res==='won')w++;else if(b.res==='lost')l++;});
  var tot=w+l,pct2=tot>0?Math.round(w/tot*100):0;
  if(sc)sc.innerHTML='<div class="scorecard"><div class="scbadge" style="background:var(--gold)">'+pct2+'% réussite</div>'+
    '<div class="scgrid"><div><div class="scn">'+w+'</div><div class="sck">Réussies</div></div>'+
    '<div><div class="scn">'+l+'</div><div class="sck">Ratées</div></div>'+
    '<div><div class="scn">'+tot+'</div><div class="sck">Total</div></div></div></div>';
  host.innerHTML=bets.map(function(b){
    var cls=b.res==='won'?'won':b.res==='lost'?'lost':'';
    var d=new Date(b.id);
    var dt=d.toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit',year:'2-digit'})+' '+d.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
    var res={'won':'✅ Réussie','lost':'❌ Ratée','void':'Annulée','pending':'En attente'}[b.res]||b.res;
    return '<div class="hist-ticket '+cls+'">'+
      '<div class="ht"><span>'+esc(b.m)+'</span><span>'+(b.res==='won'?'<span style="color:var(--green)">'+res+'</span>':b.res==='lost'?'<span style="color:var(--red)">'+res+'</span>':res)+'</span></div>'+
      '<div class="hd">'+dt+'</div>'+
      '<div class="hp">'+esc(b.sel||'—')+' · cote '+b.odds.toFixed(2)+' · mise '+b.stake.toFixed(2)+'</div>'+
    '</div>';
  }).join('');
}

