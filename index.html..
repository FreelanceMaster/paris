/* ─── Sacoche Modal ─── */
function openSacoche(){
  var cur = store.start || 0;
  var ov = document.createElement('div');
  ov.id = 'bp-sac-ov';
  ov.innerHTML =
    '<div id="bp-sac-box">' +
      '<h3>MA SACOCHE</h3>' +
      '<p>Solde de départ actuel : ' + cur.toFixed(2) + ' €</p>' +
      '<input id="bp-sac-val" type="number" step="0.01" min="0" value="' + cur + '">' +
      '<div id="bp-sac-row">' +
        '<button id="bp-sac-no">Annuler</button>' +
        '<button id="bp-sac-ok">✓ CONFIRMER</button>' +
      '</div>' +
    '</div>';
  document.body.appendChild(ov);
  var inp = document.getElementById('bp-sac-val');
  inp.focus(); inp.select();
  function confirm_save() {
    var v = parseFloat(inp.value);
    if (!isNaN(v) && v >= 0) {
      store.start = v;
      document.getElementById('startbk').value = v;
      save();
      render();
    }
    ov.remove();
  }
  document.getElementById('bp-sac-ok').onclick = confirm_save;
  document.getElementById('bp-sac-no').onclick = function(){ ov.remove(); };
  inp.onkeydown = function(e){ if(e.key==='Enter') confirm_save(); if(e.key==='Escape') ov.remove(); };
  ov.onclick = function(e){ if(e.target===ov) ov.remove(); };
}

