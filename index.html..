function buildAnalysis(m,r){
  var probs=[[r.pW,'la victoire de '+fr(m.t1)],[r.pD,'le match nul'],[r.pL,'la victoire de '+fr(m.t2)]];
  probs.sort(function(a,b){return b[0]-a[0];});
  var pick=probs[0],sec=probs[1],conf=Math.round(pick[0]*100);
  var fav=r.pW>=r.pL?m.t1:m.t2,reason;
  if(Math.abs(r.pW-r.pL)<0.07)reason='les deux équipes se valent, ça peut basculer des deux côtés';
  else{reason=fr(fav)+' a le meilleur niveau global';
    if(r.hostA||r.hostB){var hh=r.hostA?m.t1:m.t2;if(hh===fav)reason+=', avec en plus l\'avantage du terrain';}}
  var caveat='Mais '+sec[1]+' reste possible ('+Math.round(sec[0]*100)+'%), rien n\'est joué.';
  if(r.played<1)caveat='À confirmer : peu de matchs joués pour l\'instant, je m\'appuie surtout sur l\'avant-tournoi.';
  return '🧠 Mon analyse : je penche pour '+pick[1]+' (confiance '+conf+'%). '+cap(reason)+'. '+caveat;
}
