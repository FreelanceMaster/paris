function formLev(t){var f=FORM[t];if(!f||f[0]<3)return null;var ppg=(3*f[1]+f[2])/f[0];return Math.max(0.72,Math.min(1.45,0.72+(ppg/3)*0.73));}
function formStr(t){var f=FORM[t];return f?f[1]+'V '+f[2]+'N '+f[3]+'D ('+f[0]+' matchs)':'—';}
function lev(t){
  var p=RATING[t], base=p?Math.max(0.72,Math.min(1.45,1+(p-1580)/620)):1;
  var fl=formLev(t);
  return fl===null?base:0.75*base+0.25*fl;     // pondération interne
}
function strength(t){
  var x=STR[t], L=lev(t), P=3;                    // P = poids du niveau de base (3 "matchs")
  if(!x)return {att:L,def:1/L,n:0};               // pas encore joué : on part du niveau de base
  var es=(x.s+P*L*AVG)/(x.n+P), ec=(x.c+P*(1/L)*AVG)/(x.n+P);  // mélange niveau de base + résultats réels
  return {att:es/AVG, def:ec/AVG, n:x.n};
}

/* ---------- moteur de calcul (confidentiel) ---------- */
function fact(n){var r=1;for(var i=2;i<=n;i++)r*=i;return r;}
function pois(k,l){return Math.exp(-l)*Math.pow(l,k)/fact(k);}
function model(lA,lB){
  var M=10,pW=0,pD=0,pL=0,o05=0,o15=0,o25=0,o35=0,btts=0,best=0,bi=0,bj=0;
  for(var i=0;i<=M;i++)for(var j=0;j<=M;j++){
    var p=pois(i,lA)*pois(j,lB);
    if(i>j)pW+=p;else if(i===j)pD+=p;else pL+=p;
    var t=i+j;
    if(t>0)o05+=p; if(t>1)o15+=p; if(t>2)o25+=p; if(t>3)o35+=p;
    if(i>0&&j>0)btts+=p;
    if(p>best){best=p;bi=i;bj=j;}
  }
  var pNo=Math.exp(-(lA+lB)), s=lA+lB;
  var pA1=s>0?(lA/s)*(1-pNo):0, pB1=s>0?(lB/s)*(1-pNo):0;
  return {pW:pW,pD:pD,pL:pL,o05:o05,o15:o15,o25:o25,o35:o35,btts:btts,
    pA1st:pA1,pB1st:pB1,pNoGoal:pNo,lA:lA,lB:lB,score:bi+'-'+bj};
