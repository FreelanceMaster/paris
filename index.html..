/* ---------- recalcul en direct (mi-temps / pause) ---------- */
function inplay(i){
  var m=MATCHES[i];if(!m)return;
  var gh=parseInt(gv('ips1_'+i),10)||0, ga=parseInt(gv('ips2_'+i),10)||0;
  var mn=parseInt(gv('ipm_'+i),10)||0;
  var minLeft=Math.max(0,90-mn);
  var r=predictMatch(m);
  var lhr=Math.max(0.001,r.lA*minLeft/90), lar=Math.max(0.001,r.lB*minLeft/90);
  var M=12,pW=0,pD=0,pL=0;
  for(var x=0;x<=M;x++)for(var y=0;y<=M;y++){var p=pois(x,lhr)*pois(y,lar);
    var fh=gh+x,fa=ga+y; if(fh>fa)pW+=p; else if(fh===fa)pD+=p; else pL+=p;}
  function odd(p){return p>0?(1/p).toFixed(2):'—';}
  function c(lbl,p,key){return '<div class="pb" onclick="event.stopPropagation();sendToValue('+i+",'"+key+"',"+p.toFixed(4)+')"><div class="o">'+lbl+'</div><div class="p">'+(p*100).toFixed(0)+'%</div><div class="c">cote juste '+odd(p)+'</div><div class="send">→ tester</div></div>';}
  document.getElementById('ipres_'+i).innerHTML='<div class="autres">Recalcul à '+gh+'-'+ga+' ('+mn+"')</div><div class=\"bars\">"+
    c('1 — '+abbr(m.t1),pW,'1')+c('Nul',pD,'X')+c('2 — '+abbr(m.t2),pL,'2')+'</div>';
}
function setMin(i,v){document.getElementById('ipm_'+i).value=v;inplay(i);}

/* ---------- simulation (rejouer le match) ---------- */
function randPois(l){var L=Math.exp(-l),k=0,p=1;do{k++;p*=Math.random();}while(p>L);return k-1;}
function simulate(i){
  var m=MATCHES[i];if(!m)return;
  var r=predictMatch(m),N=1000000,lA=r.lA,lB=r.lB;
  var w=0,d=0,l=0,scores={},tot=0;
  for(var n=0;n<N;n++){var a=randPois(lA),b=randPois(lB);
    if(a>b)w++;else if(a===b)d++;else l++;tot+=a+b;
    var k=a+'-'+b;scores[k]=(scores[k]||0)+1;}
  var top=Object.keys(scores).sort(function(x,y){return scores[y]-scores[x];}).slice(0,5);
  function odd(p){return p>0?(1/p).toFixed(2):'—';}
  function c(lbl,cnt,key){var p=cnt/N;return '<div class="pb" onclick="event.stopPropagation();sendToValue('+i+",'"+key+"',"+p.toFixed(4)+')"><div class="o">'+lbl+'</div><div class="p">'+(p*100).toFixed(0)+'%</div><div class="c">cote juste '+odd(p)+'</div><div class="send">→ tester</div></div>';}
  var sc=top.map(function(k){return '<div class="scrow"><span>'+k+'</span><span>'+(scores[k]/N*100).toFixed(0)+'%</span></div>';}).join('');
  document.getElementById('simres_'+i).innerHTML=
    '<div class="autres">Sur 1 000 000 matchs rejoués</div>'+
    '<div class="bars">'+c('1 — '+abbr(m.t1),w,'1')+c('Nul',d,'X')+c('2 — '+abbr(m.t2),l,'2')+'</div>'+
    '<div class="scbox"><div class="iplab" style="margin-bottom:2px">Scores les plus fréquents</div>'+sc+
    '<div class="scrow" style="border:0;color:var(--txt-dim)"><span>Buts en moyenne</span><span>'+(tot/N).toFixed(1)+'</span></div></div>';
}

