function computeStrengths(){
  STR={};var tot=0,games=0;
  MATCHES.forEach(function(m){
    if(!m.ft)return;
    games++;tot+=m.ft[0]+m.ft[1];
    add(m.t1,m.ft[0],m.ft[1]);add(m.t2,m.ft[1],m.ft[0]);
  });
  AVG=games>0?(tot/(games*2)):1.35;
  function add(t,s,c){if(!STR[t])STR[t]={s:0,c:0,n:0,w:0,d:0,l:0};STR[t].s+=s;STR[t].c+=c;STR[t].n++;
    if(s>c)STR[t].w++;else if(s===c)STR[t].d++;else STR[t].l++;}
}
